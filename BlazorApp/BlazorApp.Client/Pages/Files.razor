@page "/Files"
@using FileExstend
@rendermode pageRenderMode
@inject IFileListService service

<h3>Files [@InteractiveInfo.CurrentRenderType]</h3>

<FileUploadModalDialog NameModal="FileUploadModalDialog" OnSendFiles="GetFiles" />
<FileViewerModalDialog NameModal="FileViewerModalDialog" FilePath="@SelectedFilePath" />

<div class="card mb-3">
    <div class="card-header">
        <div class="row">
            <div class="col-auto d-flex align-items-center">
                <h5 class="card-title" style="margin:0;">
                    Список файлов
                </h5>
            </div>
            <div class="col"></div>
            <div class="col-auto d-flex align-items-center">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#FileUploadModalDialog">
                    Загрузить
                </button>
            </div>
            <div class="col-auto d-flex align-items-center">
                <button type="button"
                        class="btn btn-primary"
                        @onclick="GetFiles">
                    Обновить
                </button>
            </div>
        </div>
    </div>
    <div class="card-body">

        @if (isLoadingFiles)
        {
            <div class="d-flex justify-content-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
            </div>
        }
        else
        {
            @if (files?.Count() > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th scope="col">Имя</th>
                                <th scope="col">Путь</th>
                                <th scope="col">Размер</th>
                                <th scope="col">Дата создания</th>
                                <th scope="col">Действия</th>
                            </tr>
                        </thead>
                        <tbody class="table-group-divider">
                            @foreach (Models.FileItem file in files)
                            {
                                <tr>
                                    <th scope="row">@file.Name</th>
                                    <td>@file.Path</td>
                                    <td>@FileExstensionHelper.FormatBytes(file.Length)</td>
                                    <td>@file.CreationTime</td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#FileViewerModalDialog"
                                                @onclick="() => SelectedFilePath = file.Path">
                                            Просмотр
                                        </button>
                                        <form action="/File/Download" method="post" style="display: inline;">
                                            <AntiforgeryToken />
                                            <input type="hidden" value="@file.Path" name="Path" />
                                            <button class="btn btn-primary" type="submit">Скачать</button>
                                        </form>
                                        <button type="button"
                                                class="btn btn-danger"
                                                @onclick="async () => await DeleteFile(file.Path)">
                                            Удалить
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
    <div class="card-footer">
    </div>
</div>


@code {
    private static IComponentRenderMode pageRenderMode = RenderMode.InteractiveAuto;
    private InteractiveInfoService InteractiveInfo { get; set; }

    private CancellationTokenSource _pageLifetimeCts = new();
    // Токен, который срабатывает при закрытии/уничтожении страницы
    public CancellationToken PageLifetimeToken => _pageLifetimeCts.Token;

    public bool isLoadingFiles { get; private set; } = false;

    private string SelectedFilePath = string.Empty;
    private IEnumerable<Models.FileItem>? files;

    protected override async Task OnInitializedAsync()
    {
        InteractiveInfo = new InteractiveInfoService(RendererInfo, AssignedRenderMode);
        if (InteractiveInfo.IsWaitingInteractive == false)
        {
            await GetFiles();
        }
        await base.OnInitializedAsync();
    }

    public async Task GetFiles()
    {
        isLoadingFiles = true;
        StateHasChanged();
        files = await service.GetFiles(PageLifetimeToken);
        isLoadingFiles = false;
        StateHasChanged();
    }

    public async Task DeleteFile(string path)
    {
        isLoadingFiles = true;
        StateHasChanged();
        await service.DeleteFile(path, PageLifetimeToken);
        files = await service.GetFiles(PageLifetimeToken);
        isLoadingFiles = false;
        StateHasChanged();
    }

    // Флаг для отслеживания состояния
    private bool _isDisposed;
    // Освобождение ресурсов при уничтожении компонента
    public async ValueTask DisposeAsync()
    {
        if (_isDisposed) return;

        _isDisposed = true;

        // Отменяем все операции
        _pageLifetimeCts?.Cancel();
        // Освобождаем ресурсы
        _pageLifetimeCts?.Dispose();
    }
}
