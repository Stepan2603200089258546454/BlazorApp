@using FileExstend
@using FileExstend.Models

@if (string.IsNullOrEmpty(FilePath) == false)
{
    @if (FileEx.Type == FileType.Image)
    {
        <div class="text-center">
            <img src="@FilePath" class="rounded" alt="Изображение" loading="lazy" style="max-width: 100%; max-height:82vh;">
        </div>
    }
    else if (FileEx.Type == FileType.Video)
    {
        <center>
            <div class="embed-responsive embed-responsive-16by9">
                <video controls preload="metadata" style="max-width: 100%; max-height:82vh;">
                    <source class="embed-responsive-item" src="@FilePath" />
                </video>
            </div>
        </center>
    }
    else if (FileEx.Type == FileType.Audio)
    {
        <center>
            <figure>
                <audio controls src="@FilePath" preload="metadata" style="width: 100%"></audio>
            </figure>
        </center>
    }
    else if (FileEx.Type is FileType.PDF or FileType.Text or FileType.Web)
    {
        <center>
            <iframe src="@FilePath" loading="lazy" style="width: 100%; height:82vh;">
            </iframe>
        </center>
    }
    else
    {
        <div class="alert alert-danger" role="alert">
            Тип файла не поддерживает просмотр
        </div>
    }
}
else
{
    <div class="alert alert-danger" role="alert">
        Не передан файл
    </div>
}

@code {
    [Parameter, EditorRequired]
    public string FilePath { get; set; }

    private FileExstension FileEx;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(FilePath) == false)
            FileEx = FileExstensionHelper.GetExtensionType(FilePath);
        await base.OnInitializedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(FilePath) == false)
            FileEx = FileExstensionHelper.GetExtensionType(FilePath);
        await base.OnParametersSetAsync();
    }
}
